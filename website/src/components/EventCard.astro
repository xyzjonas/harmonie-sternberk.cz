---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import LocationIcon from "./icons/LocationIcon.astro";

interface Props {
  event: CollectionEntry<"events">;
}

const { event } = Astro.props;
const heroImage = event.data.heroImage || "/placeholder-hero.jpg";
const hasTime = event.data.hasTime ?? true;
---

<article class="event-card">
  <a href={`/events/${event.id}`} class="event-card-link">
    <div class="event-card-image">
      <Image src={heroImage} alt={event.data.title} width={600} height={400} />
    </div>

    <div class="event-card-body">
      <time datetime={event.data.datetime.toISOString()}>
        {
          event.data.datetime.toLocaleDateString("cs-CZ", {
            day: "numeric",
            month: "long",
            year: "numeric",
          })
        }
      </time>

      <h3>{event.data.title}</h3>

      <p class="description">{event.data.description}</p>
    </div>

    <div class="event-card-footer">
      <time datetime={event.data.datetime.toISOString()}>
        {
          event.data.datetime.toLocaleDateString("cs-CZ", {
            day: "numeric",
            month: "long",
            year: "numeric",
          })
        }
      </time>

      <span class="button-like"> Více informací </span>
    </div>
  </a>
</article>

<style>
  .event-card {
    background: #ffffff;
    border: 1px solid rgba(227, 5, 26, 0.1);
    border-radius: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s ease;
  }

  .event-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .event-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .event-card-image {
    width: 100%;
    height: 300px;
    overflow: hidden;
  }

  .event-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .event-card-image img[src="/placeholder-hero.jpg"] {
    border-bottom: 1px solid rgba(227, 5, 26, 0.1);
  }

  .event-card-body {
    padding: 2rem;
    flex: 1;
  }

  .event-card time {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .event-card h3 {
    margin: 0 0 1rem 0;
    font-size: 1.75rem;
    font-family: var(--font-serif);
    font-weight: 600;
    color: var(--on-surface);
  }

  .event-card .description {
    margin: 0;
    color: var(--on-surface);
    line-height: 1.6;
    font-size: 1rem;
  }

  .event-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-top: 1px solid rgba(227, 5, 26, 0.1);
  }

  .event-card-footer .location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(26, 28, 30, 0.6);
  }
</style>
