---
const today = new Date();
---

<footer>
  <div class="footer-container">
    <div class="footer-section branding">
      <h2>Harmonie Šternberk</h2>
      <p class="copyright">&copy; {today.getFullYear()} Harmonie Šternberk</p>
    </div>

    <div class="footer-section partners">
      <a
        href="https://www.sternberk.eu/"
        target="_blank"
        rel="noopener noreferrer">Město Šternberk</a
      >
      <a
        href="https://www.zus-sternberk.cz/"
        target="_blank"
        rel="noopener noreferrer">ZUŠ Šternberk</a
      >
      <a href="http://sdo-cr.cz/" target="_blank" rel="noopener noreferrer"
        >SDOČR</a
      >
    </div>

    <div class="footer-section social">
      <div class="social-links">
        <a
          href="https://www.instagram.com/harmonie_sternberk"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/pages/category/Musician-band/Harmonie-%C5%A0ternberk-116944264377/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.youtube.com/channel/UCkTMDhD8DZdeOrE5NJttvFQ"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"
            ></path>
            <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"
            ></polygon>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--surface-container-low);
    border-top: 1px solid rgba(227, 5, 26, 0.1);
    margin-top: auto;
  }

  .footer-container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }

  /* Branding Section */
  .branding h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--primary-dark) !important;
    margin: 0 0 0.5rem 0;
    letter-spacing: 0.01em;
  }

  .branding .copyright {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: rgba(26, 28, 30, 0.4);
    margin: 0;
  }

  /* Partners Section */
  .partners {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .partners a {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(26, 28, 30, 0.6);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s ease;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .partners a:hover {
    color: var(--primary);
  }

  /* Social Section */
  .social-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: rgba(26, 28, 30, 0.6);
    transition: color 0.2s ease;
  }

  .social-links a:hover {
    color: var(--primary);
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      gap: 2.5rem;
      text-align: center;
      padding: 2rem 1.5rem;
    }

    .branding h2 {
      font-size: 1.75rem;
    }

    .partners {
      flex-direction: column;
      gap: 0.75rem;
    }

    .social-links {
      justify-content: center;
    }
  }
</style>
