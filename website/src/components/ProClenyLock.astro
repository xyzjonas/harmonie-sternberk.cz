<div class="pro-cleny-lock" data-password="harmoniejebest">
  <div class="lock-backdrop"></div>
  <div class="lock-modal">
    <h2>Pro členy</h2>
    <p>Pro přístup k této sekci zadejte heslo</p>
    <form>
      <input type="password" placeholder="Heslo" autocomplete="off" required />
      <button type="submit">Vstoupit</button>
    </form>
    <p class="caption">Pokud nevíš, zeptej se Jonáše</p>
  </div>
</div>

<script>
  const STORAGE_KEY = "proClenyUnlocked";
  const modal = document.querySelector(".pro-cleny-lock");
  const form = modal?.querySelector("form");
  const input = modal?.querySelector("input");
  const correctPassword = modal?.dataset.password;

  if (!modal) {
    throw new Error("ProClenyLock: modal not found");
  }

  // Check if already unlocked
  if (localStorage.getItem(STORAGE_KEY) === "true") {
    modal.remove();
  } else {
    modal.style.display = "flex";
    setTimeout(() => input?.focus(), 100);
  }

  // Handle form submission
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (input && input.value === correctPassword) {
      localStorage.setItem(STORAGE_KEY, "true");
      modal.remove();
    } else if (input) {
      input.value = "";
      input.classList.add("error");
      setTimeout(() => input.classList.remove("error"), 500);
    }
  });
</script>

<style>
