    justify-content: center;
  }

  .lock-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .lock-modal {
    position: relative;
    background: white;
    padding: 3rem 2.5rem;
    border-radius: 0;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-width: 400px;
    width: calc(100% - 2rem);
    text-align: center;
  }

  .lock-modal h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    color: var(--primary);
    margin: 0 0 0.75rem 0;
  }

  .lock-modal p {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--on-surface);
    margin: 0 0 2rem 0;
  }

  .lock-modal form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lock-modal input {
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.875rem 1.25rem;
    border: 2px solid rgba(0, 0, 0, 0.1);
    border-radius: 0;
    outline: none;
    transition: all 0.2s;
  }

  .lock-modal input:focus {
    border-color: var(--primary);
  }

  .lock-modal input.error {
    border-color: #e3051a;
    animation: shake 0.5s;
  }

  @keyframes shake {
    0%,
    100% {
      transform: translateX(0);
    }
    10%,
    30%,
    50%,
    70%,
    90% {
      transform: translateX(-8px);
    }
    20%,
    40%,
    60%,
    80% {
      transform: translateX(8px);
    }
  }

  .lock-modal button {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    padding: 1rem;
    background: var(--primary);
    color: var(--on-primary);
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: all 0.2s;
  }

  .lock-modal button:hover {
    background: var(--primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(227, 5, 26, 0.3);
  }

  .lock-modal button:active {
    transform: translateY(0);
  }

  .caption {
    margin-top: 1.5rem !important;
    margin-bottom: 0 !important;
    font-size: 0.875rem !important;
