---
import { getCollection, render } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import ProClenyLock from "../../components/ProClenyLock.astro";
import StructuredData from "../../components/StructuredData.astro";
import { SITE_TITLE } from "../../consts";

const allPosts = (await getCollection("proCleny")).sort(
  (a, b) => b.data.datetime.valueOf() - a.data.datetime.valueOf(),
);

const pinnedPost = allPosts.find((post) => post.data.isPinned);
const regularPosts = allPosts.filter((post) => !post.data.isPinned);

const pinnedContent = pinnedPost ? await render(pinnedPost) : null;

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("cs-CZ", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
};
---

<!doctype html>
<html lang="cs">
  <head>
    <BaseHead
      title={`Pro členy | ${SITE_TITLE}`}
      description="Informace a materiály pro členy Harmonie Šternberk"
    />
    <StructuredData
      breadcrumbs={[
        { name: "Domů", url: "/" },
        { name: "Pro členy", url: "/pro-cleny" },
      ]}
    />
  </head>
  <body>
    <Header />
    <ProClenyLock />
    <main>
      <h1>Pro členy</h1>

      {
        pinnedPost && pinnedContent && (
          <section class="pinned-section">
            <div class="pinned-post">
              <h2 class="pinned-title">{pinnedPost.data.title}</h2>
              <div class="pinned-content">
                <pinnedContent.Content />
              </div>
            </div>
          </section>
        )
      }

      {
        regularPosts.length > 0 && (
          <section class="posts-section">
            <div class="posts-list">
              {regularPosts.map((post) => (
                <article class="post-card">
                  <a href={`/pro-cleny/${post.id}`} class="post-link">
                    <div class="post-date">
                      {formatDate(post.data.datetime)}
                    </div>
                    <h2 class="post-title">{post.data.title}</h2>
                    {post.data.subtitle && (
                      <p class="post-subtitle">{post.data.subtitle}</p>
                    )}
                  </a>
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        !pinnedPost && regularPosts.length === 0 && (
          <p class="no-posts">Zatím nejsou k dispozici žádné příspěvky.</p>
        )
      }
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 4rem 1rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 3rem;
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    font-weight: 600;
  }

  .posts-section {
    max-width: 1200px;
    margin: 0 auto;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    background: var(--surface);
    border-radius: 0;
    overflow: hidden;
    transition: all 0.3s ease;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .post-card:hover {
    border-color: var(--primary);
  }

  .pinned-section {
    max-width: 1200px;
    margin: 0 auto 3rem auto;
  }

  .pinned-post {
    background: var(--surface);
    border: 2px solid var(--primary);
    border-radius: 0;
    padding: 2rem;
  }

  .pinned-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    margin: 0 0 1.5rem 0;
    color: var(--primary);
  }

  .pinned-content {
    color: var(--on-surface);
    line-height: 1.7;
  }

  .pinned-content :global(p) {
    margin: 0.75rem 0;
  }

  .pinned-content :global(ul),
  .pinned-content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .pinned-content :global(li) {
    margin: 0.5rem 0;
  }

  .pinned-content :global(strong) {
    font-weight: 600;
    color: var(--on-surface);
  }

  .post-link {
    display: block;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--primary);
    font-weight: 500;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--on-surface);
    line-height: 1.3;
  }

  .post-subtitle {
    font-size: 1.125rem;
    color: var(--on-surface-variant);
    margin: 0;
    line-height: 1.5;
  }

  .no-posts {
    text-align: center;
    padding: 3rem;
    color: #666;
    font-size: 1.125rem;
  }

  @media (max-width: 768px) {
    main {
      padding: 3rem 1rem;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
    }

    .pinned-post {
      padding: 1.5rem;
    }

    .pinned-title {
      font-size: 1.5rem;
    }

    .post-link {
      padding: 1.5rem;
    }

    .post-title {
      font-size: 1.5rem;
    }

    .post-subtitle {
      font-size: 1rem;
    }
  }
</style>
